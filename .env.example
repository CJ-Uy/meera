# Groq is the default provider. Supported values: groq, ollama.
AI_PROVIDER=groq
# Optional fallback when the primary provider fails.
# AI_FALLBACK_PROVIDER=ollama

# Required when AI_PROVIDER=groq. Keep this server-side.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_TOKENS=512
GROQ_REQUEST_TIMEOUT_MS=30000

# Optional Ollama provider/fallback.
OLLAMA_BASE_URL=https://ollama.cjuy.dev
OLLAMA_CHAT_MODEL=qwen3.5:9b
OLLAMA_VISION_MODEL=qwen3-vl:8b
OLLAMA_CHAT_CONTEXT=8192
OLLAMA_VISION_CONTEXT=4096
# Caps text-only replies. Vision replies are intentionally uncapped so Qwen3-VL can finish thinking and emit its tool call.
OLLAMA_MAX_TOKENS=256
# Total vision request budget. Meera splits this across an initial attempt and one timeout recovery attempt.
OLLAMA_REQUEST_TIMEOUT_MS=85000

# Optional. Keep all provider credentials server-side and never prefix them with NEXT_PUBLIC_.
# OLLAMA_API_KEY=
