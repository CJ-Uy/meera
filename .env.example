# Meera uses Groq as its only AI provider.

# Required. Keep this server-side. Never prefix it with NEXT_PUBLIC_.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.1-8b-instant
# Groq's only multimodal model — used for screen understanding and overlay placement.
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_TOKENS=512
GROQ_REQUEST_TIMEOUT_MS=30000
# Text model used for element selection over the candidate list (stronger reasoner than the chat model).
GROQ_SELECTION_MODEL=llama-3.3-70b-versatile

# Public remote demo API. This lets local devs use the shared Cloudflare D1-backed admin CMS
# without a Cloudflare account.
NEXT_PUBLIC_ADMIN_DEMO_API_BASE=https://meera-admin-demo-api.cj-uy.workers.dev
# Client-side toggle (optional). Set to 0 to disable the zoom-refine grounding pass for raw speed.
# NEXT_PUBLIC_MEERA_GROUNDING_REFINE=1

# local | shared | production
APP_ENV=local

# local | api | r2-s3 | binding
STORAGE_MODE=local

# Shared API mode. Outside developers receive these in their private .env.local.
SHARED_API_BASE_URL=
SHARED_API_TOKEN=

# R2 S3-compatible mode for local/shared dev only. Never use production bucket credentials here.
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=

# Local fallback
LOCAL_SQLITE_PATH=./.local/dev.db
LOCAL_STORAGE_DIR=./.local/uploads

# ------------------------------------------------------------
# Cloudflare Workers AI (via AI Gateway, OpenAI-compatible). Server-side only.
# ------------------------------------------------------------
# Default = AI Gateway compat endpoint. Direct (no gateway) alt is commented below;
# if you use the direct URL, drop the "workers-ai/" prefix from model ids.
# Create or reuse an AI Gateway id, then replace <GATEWAY_ID>.
WORKERS_AI_BASE_URL=https://gateway.ai.cloudflare.com/v1/8527ec1369d46f55304a6f59ab5356e4/<GATEWAY_ID>/compat
# WORKERS_AI_BASE_URL=https://api.cloudflare.com/client/v4/accounts/8527ec1369d46f55304a6f59ab5356e4/ai/v1
# Create a Cloudflare API token scoped to this account with Workers AI: Read.
WORKERS_AI_API_KEY=
# Only set this if the AI Gateway is configured as authenticated.
# WORKERS_AI_GATEWAY_AUTH_TOKEN=
WORKERS_AI_PLAYGROUND_MODEL=workers-ai/@cf/meta/llama-3.1-8b-instruct
