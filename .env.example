# Meera uses Groq as its only AI provider.

# Required. Keep this server-side. Never prefix it with NEXT_PUBLIC_.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.1-8b-instant
# Groq's only multimodal model — used for screen understanding and overlay placement.
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_TOKENS=512
GROQ_REQUEST_TIMEOUT_MS=30000

# Optional Ollama provider/fallback.
OLLAMA_BASE_URL=https://ollama.cjuy.dev
OLLAMA_CHAT_MODEL=qwen3.5:9b
OLLAMA_VISION_MODEL=qwen3-vl:8b
OLLAMA_CHAT_CONTEXT=8192
OLLAMA_VISION_CONTEXT=4096
# Caps text-only replies. Vision replies are intentionally uncapped so Qwen3-VL can finish thinking and emit its tool call.
OLLAMA_MAX_TOKENS=256
# Total vision request budget. Meera splits this across an initial attempt and one timeout recovery attempt.
OLLAMA_REQUEST_TIMEOUT_MS=85000

# Optional. Keep all provider credentials server-side and never prefix them with NEXT_PUBLIC_.
# OLLAMA_API_KEY=

# Public remote demo API. This lets local devs use the shared Cloudflare D1-backed admin CMS
# without a Cloudflare account.
NEXT_PUBLIC_ADMIN_DEMO_API_BASE=https://meera-admin-demo-api.cj-uy.workers.dev
# Client-side toggle (optional). Set to 0 to disable the zoom-refine grounding pass for raw speed.
# NEXT_PUBLIC_MEERA_GROUNDING_REFINE=1
