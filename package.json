{
	"name": "meera",
	"version": "0.1.0",
	"private": true,
	"main": "dist-electron/main.cjs",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"test": "vitest run",
		"desktop:build": "node scripts/build-electron.mjs",
		"desktop:launch": "wait-on http://localhost:3000 && node scripts/desktop-launch.mjs",
		"desktop:dev": "pnpm desktop:build && concurrently -k -n web,desktop -c blue,green \"pnpm dev\" \"pnpm desktop:launch\"",
		"desktop:start": "pnpm build && pnpm desktop:build && concurrently -k -n web,desktop -c blue,green \"pnpm start\" \"pnpm desktop:launch\"",
		"desktop:smoke": "pnpm desktop:build && node scripts/desktop-smoke.mjs",
		"dev:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"ai:models": "node --env-file=.env.local scripts/workers-ai-playground.mjs --list",
		"ai:chat": "node --env-file=.env.local scripts/workers-ai-playground.mjs",
		"deploy": "pnpm deploy:prod",
		"deploy:dev": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env dev",
		"deploy:shared-api": "wrangler deploy --config wrangler.shared-dev-api.jsonc",
		"deploy:prod": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env production",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply meera-dev-db --local",
		"db:migrate:dev": "wrangler d1 migrations apply meera-dev-db --remote",
		"db:migrate:prod": "wrangler d1 migrations apply meera-prod-db --remote",
		"db:studio": "drizzle-kit studio",
		"typecheck": "tsc --noEmit",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1064.0",
		"@opennextjs/cloudflare": "^1.19.9",
		"@xyflow/react": "^12.8.5",
		"drizzle-orm": "^0.45.2",
		"next": "16.2.6",
		"react": "^19.1.7",
		"react-dom": "^19.1.7",
		"recharts": "^3.8.1",
		"tesseract.js": "^7.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^20",
		"@types/react": "^19.1.7",
		"@types/react-dom": "^19.1.7",
		"better-sqlite3": "^12.10.0",
		"concurrently": "^10.0.3",
		"drizzle-kit": "^0.31.10",
		"electron": "^42.3.3",
		"esbuild": "^0.28.0",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"vitest": "^4.1.8",
		"wait-on": "^9.0.10",
		"wrangler": "^4.98.0"
	}
}
