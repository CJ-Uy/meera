{
	"name": "meera",
	"version": "0.1.0",
	"private": true,
	"main": "dist-electron/main.cjs",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"test": "vitest run",
		"desktop:build": "node scripts/build-electron.mjs",
		"desktop:launch": "wait-on http://localhost:3000 && node scripts/desktop-launch.mjs",
		"desktop:dev": "pnpm desktop:build && concurrently -k -n web,desktop -c blue,green \"pnpm dev\" \"pnpm desktop:launch\"",
		"desktop:start": "pnpm build && pnpm desktop:build && concurrently -k -n web,desktop -c blue,green \"pnpm start\" \"pnpm desktop:launch\"",
		"desktop:smoke": "pnpm desktop:build && node scripts/desktop-smoke.mjs",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.19.9",
		"next": "16.2.6",
		"react": "^19.1.7",
		"react-dom": "^19.1.7",
		"tesseract.js": "^7.0.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19.1.7",
		"@types/react-dom": "^19.1.7",
		"concurrently": "^10.0.3",
		"electron": "^42.3.3",
		"esbuild": "^0.28.0",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"vitest": "^4.1.8",
		"wait-on": "^9.0.10",
		"wrangler": "^4.98.0"
	}
}
